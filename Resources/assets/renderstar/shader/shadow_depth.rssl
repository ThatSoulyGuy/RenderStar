#rssl 1

@uniform ShadowMVP : binding(0)
{
    mat4 model;
    mat4 lightViewProjection;
    vec4 _unused;
}

@stage vertex
@input inPosition : location(0), vec3
@input inNormal : location(1), vec3
@input inTexCoord : location(2), vec2
@input inTangent : location(3), vec3

void main() {
    gl_Position = ubo.lightViewProjection * ubo.model * vec4(inPosition, 1.0);
}

@stage fragment
@output outColor : location(0), vec4

void main() {
    outColor = vec4(gl_FragCoord.z, 0.0, 0.0, 1.0);
}
